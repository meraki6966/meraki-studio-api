# ─── Server ──────────────────────────────────────────────────────────
PORT=19789

# ─── AI Video Generation ─────────────────────────────────────────────
# Primary: Replicate (Kling, Flux, Whisper)
REPLICATE_API_TOKEN=r8_your_token_here

# Fallback: fal.ai (Kling, Wan 2.1, Minimax)
FAL_KEY=your_fal_key_here

# ─── Asset Storage ────────────────────────────────────────────────────
# Cloudinary (you already have this from Nail Check + VeloxSync)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Data Storage ─────────────────────────────────────────────────────
# Local path for project files and renders (Railway: use /app/data or a mounted volume)
DATA_DIR=./data

# ─── CORS ─────────────────────────────────────────────────────────────
# Your Vercel app URL (set this in Railway after deploying the frontend)
FRONTEND_URL=http://localhost:5173
